# ──────────────────────────────────────────
# ZunoBio — Environment Variables
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.
# ──────────────────────────────────────────

# Supabase — get these from your Supabase project dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# App URL — change to your production domain when deploying
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Stripe ──
# Get from dashboard.stripe.com > Developers > API Keys
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
# Get from Stripe > Developers > Webhooks > your endpoint > Signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# ── YouTube Data API ──
# Get from console.cloud.google.com > APIs > YouTube Data API v3 > Credentials
YOUTUBE_API_KEY=AIza...

# ── TikTok (via RapidAPI) ──
# Sign up at rapidapi.com, subscribe to "TikTok Scraper" API
RAPIDAPI_KEY=your-rapidapi-key
RAPIDAPI_HOST=tiktok-scraper7.p.rapidapi.com

# ── Cron secret (generate any random string) ──
# Used to authenticate Vercel cron job calls
CRON_SECRET=your-random-secret-string

# ── Mailchimp (optional) ──
# For syncing email subscribers to Mailchimp
MAILCHIMP_API_KEY=
MAILCHIMP_SERVER_PREFIX=us1
MAILCHIMP_LIST_ID=
